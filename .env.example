# air.grid — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local (see .gitignore).
# All keys below are free tiers; each has rate limits — cache aggressively.

# ── Live air quality ──────────────────────────────────────────────────────────
# AirNow (EPA, official AQI):   https://docs.airnowapi.org/  (request a key)
BCFAFCCC-D72A-4A29-AC79-9EC26306A1F6

# PurpleAir (dense PM2.5 sensors): https://develop.purpleair.com/  (request a READ key)
6AF8D425-5DE8-11F1-B596-4201AC1DC123

# OpenAQ (aggregator):          https://docs.openaq.org/  (register for an API key)
f1c237d1f93b2547a7e94b1acaa45a70b3cf0130a29982e5ef75e58a4d12feaa

# ── Demographics ──────────────────────────────────────────────────────────────
# U.S. Census (ACS):            https://api.census.gov/data/key_signup.html
ffecc931bff4733a47d6c8cefcee55e3c8df4c8a

# ── Weather / wind ────────────────────────────────────────────────────────────
# NWS api.weather.gov needs NO key, but REQUIRES a User-Agent with contact info.
# Used as the request header so they can reach you if your client misbehaves.
NWS_CONTACT_EMAIL=your.email@example.com

# ── Map basemap ───────────────────────────────────────────────────────────────
# Default stack (MapLibre + CARTO dark basemap) needs NO token. Leave blank.
# Only set this if you switch the basemap to Mapbox.
# NEXT_PUBLIC_MAPBOX_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL (used for absolute links / OG tags). Set in Vercel for prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000